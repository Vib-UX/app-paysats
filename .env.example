# Privy (wajib untuk auth)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Database
DATABASE_URL="file:./prisma/dev.db"

# Enkripsi kredensial per-user (64 karakter hex)
ENCRYPTION_KEY=

# IDRX API organisasi
IDRX_API_BASE_URL=
IDRX_ORG_API_KEY=
IDRX_ORG_API_SECRET=

# Token IDRX on-chain (Base default ada di kode; override jika perlu)
NEXT_PUBLIC_IDRX_TOKEN_ADDRESS=
IDRX_TOKEN_ADDRESS=

# Chain — Base mainnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453
BASE_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Token BTC terbungkus di Base (cbBTC) — opsional; untuk tab saldo BTC.
# Hanya satu alamat (42 char). Contoh Base mainnet:
# NEXT_PUBLIC_BTC_ERC20_ADDRESS=0xcbB7C0000aB88B473b1f5aFd9ef808440eed33Bf
NEXT_PUBLIC_BTC_ERC20_ADDRESS=

# --- MCP agent (Claude) -----------------------------------------------------
# Auth model: Privy OAuth 2.0 Device Authorization Grant ("Authorized wallet
# access for self-hosted agents"). Enable it in the Privy Dashboard
# (Authentication -> Advanced -> Enable for CLI and agent access) and set the
# Verification URI to the hosted approval page below. The MCP server obtains a
# per-user access token (used as a user_jwt to sign wallet RPC) — no static
# authorization key or session-signer policy is needed.

# Base URL of the hosted Verification page (also set as the Privy Verification
# URI, with the /verification path). Used as a fallback if Privy does not return
# verification_uri_complete.
VERIFICATION_BASE_URL=https://app.paysats.exchange

# --- Deprecated (previous session-signer model; no longer used) -------------
# PRIVY_AUTHORIZATION_KEY=
# PRIVY_AGENT_SIGNER_ID=
# NEXT_PUBLIC_PRIVY_AGENT_SIGNER_ID=
# PRIVY_AGENT_POLICY_ID=
# NEXT_PUBLIC_PRIVY_AGENT_POLICY_ID=
