# Privy (wajib untuk auth)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Database
DATABASE_URL="file:./prisma/dev.db"

# Enkripsi kredensial per-user (64 karakter hex)
ENCRYPTION_KEY=

# IDRX API organisasi
IDRX_API_BASE_URL=
IDRX_ORG_API_KEY=
IDRX_ORG_API_SECRET=

# Token IDRX on-chain (Base default ada di kode; override jika perlu)
NEXT_PUBLIC_IDRX_TOKEN_ADDRESS=
IDRX_TOKEN_ADDRESS=

# Chain — Base mainnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453
BASE_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Token BTC terbungkus di Base (cbBTC) — opsional; untuk tab saldo BTC.
# Hanya satu alamat (42 char). Contoh Base mainnet:
# NEXT_PUBLIC_BTC_ERC20_ADDRESS=0xcbB7C0000aB88B473b1f5aFd9ef808440eed33Bf
NEXT_PUBLIC_BTC_ERC20_ADDRESS=

# --- MCP agent (Claude) -----------------------------------------------------
# Session-signer authorization private key (base64 PKCS8, no PEM headers). The
# matching public key is registered as a signer in the Privy Dashboard. The
# server uses this to execute DCA on a user's wallet after they connect.
PRIVY_AUTHORIZATION_KEY=
# The Privy signer id users grant via addSigners during /connect. Expose the
# NEXT_PUBLIC_ variant so the browser connect flow can reference it.
PRIVY_AGENT_SIGNER_ID=
NEXT_PUBLIC_PRIVY_AGENT_SIGNER_ID=
# Policy id scoping the signer to PaySatsDCA + IDRX approve (see services/privy/policy.ts).
PRIVY_AGENT_POLICY_ID=
NEXT_PUBLIC_PRIVY_AGENT_POLICY_ID=
