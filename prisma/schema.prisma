generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  privyUserId           String    @unique
  email                 String?
  displayName           String?
  walletAddress         String?
  onboardingCompletedAt DateTime?
  idrxUserId            Int?
  idrxApiKeyEnc         String?
  idrxApiSecretEnc      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  mintSnapshots MintRequestSnapshot[]
  creditLoans   CreditLoan[]
}

model CreditLoan {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  collateralRaw String
  borrowRaw     String
  lockTxHash    String
  borrowTxHash  String
  settleTxHash  String?
  status        String    @default("active")
  openedAt      DateTime  @default(now())
  settledAt     DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([walletAddress])
}

/// Optional local snapshot after mint / for quicker empty states; list view still uses IDRX history API.
model MintRequestSnapshot {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference       String?
  merchantOrderId String?
  toBeMinted      String?
  paymentAmount   String?
  paymentUrl      String?
  networkChainId  String?
  createdAt       DateTime @default(now())
}
