generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  privyUserId           String    @unique
  email                 String?
  displayName           String?
  walletAddress         String?
  onboardingCompletedAt DateTime?
  currencyPreference    String?   @default("IDR")
  displayUnit           String?   @default("SATS")
  idrxUserId            Int?
  idrxApiKeyEnc         String?
  idrxApiSecretEnc      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  /// Deprecated (session-signer model). Kept for backwards compatibility.
  agentSignerId         String?
  /// Deprecated (policy-scoped model). Full access is now granted via the
  /// device authorization grant, so no policy is attached.
  agentPolicyId         String?
  /// Privy wallet id the device-grant access token can act on; needed to
  /// address the wallet from the server SDK when executing on its behalf.
  agentWalletId         String?
  /// When the user approved agent access via the device-authorization flow.
  agentLinkedAt         DateTime?

  /// Device-authorization grant: per-user Privy access token (encrypted,
  /// aes-256-gcm via lib/crypto.ts). Used as a user_jwt to sign wallet RPC.
  privyDeviceAccessTokenEnc  String?
  /// When the device access token expires (refresh before/at this time).
  privyDeviceAccessTokenExp  DateTime?
  /// Device-authorization grant: refresh token (encrypted), rotated on use.
  privyDeviceRefreshTokenEnc String?

  mintSnapshots       MintRequestSnapshot[]
  creditLoans         CreditLoan[]
  payoutDestinations  PayoutDestination[]
  redeemRequests      RedeemRequest[]
  dcaExecutions       DcaExecution[]
}

/// Dynamically-registered MCP/OAuth client (RFC 7591). Claude registers itself
/// on first connect. Public clients (PKCE) — no client secret stored.
model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientName   String?
  redirectUris String[]
  createdAt    DateTime @default(now())
}

/// Short-lived params carried from /authorize to the hosted /verification page
/// and back to /api/oauth/device-complete. Holds the Privy device/user codes so
/// the bridge can poll for tokens after the user approves in the browser.
model OAuthPendingAuth {
  id                  String   @id @default(cuid())
  handle              String   @unique
  clientId            String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String?
  clientState         String?
  /// Privy device-authorization grant device_code (polled after approval).
  deviceCode          String?
  /// Privy device-authorization grant user_code (shown/used on verification).
  userCode            String?
  createdAt           DateTime @default(now())
  expiresAt           DateTime
}

/// One-time OAuth 2.1 authorization code (PKCE). Bound to a Privy user.
model OAuthAuthCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  clientId            String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String?
  privyUserId         String
  consumedAt          DateTime?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())
}

/// Opaque MCP access token issued by our authorization server. The MCP server
/// verifies the bearer against this table and resolves the Privy user.
model OAuthAccessToken {
  id          String   @id @default(cuid())
  token       String   @unique
  clientId    String
  privyUserId String
  scope       String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([privyUserId])
}

model CreditLoan {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  collateralRaw String
  borrowRaw     String
  lockTxHash    String
  borrowTxHash  String
  settleTxHash  String?
  status        String    @default("active")
  openedAt      DateTime  @default(now())
  settledAt     DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([walletAddress])
}

/// Local mirror of an IDRX-registered payout destination (bank account or e-wallet).
/// IDRX is the source of truth — this cache speeds up list rendering and lets us
/// store a per-user default + full (encrypted) account number for display.
model PayoutDestination {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idrxId               Int
  kind                 String   // 'bank' | 'ewallet'
  bankCode             String
  bankName             String
  bankAccountName      String
  /// Encrypted (aes-256-gcm via lib/crypto.ts)
  bankAccountNumberEnc String
  /// Last 4 digits for display only
  bankAccountNumberLast String
  depositWalletAddress String
  maxAmountTransfer    String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  redeemRequests RedeemRequest[]

  @@unique([userId, idrxId])
  @@index([userId])
}

/// Local snapshot of an outbound USDC transfer to a PayoutDestination deposit address.
/// Matched against IDRX DEPOSIT_REDEEM history (via transferTxHash) to surface progress.
model RedeemRequest {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutDestinationId String
  payoutDestination   PayoutDestination @relation(fields: [payoutDestinationId], references: [id], onDelete: Restrict)
  transferTxHash      String   @unique
  walletAddress       String
  /// USDC amount in 6-decimal raw units (as string)
  usdcAmountRaw       String
  /// Best-effort expected IDR out at request time (as string, IDR minor units)
  idrQuoteRaw         String?
  status              String   @default("sent") // 'sent' | 'settled' | 'failed'
  depositRedeemId     Int?
  settledAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([payoutDestinationId])
}

/// Durable per-swap history for PaySatsDCA (DCAExecuted events).
/// Populated opportunistically from on-chain logs on each /api/dca/executions
/// fetch. Kept in the DB so the UI can surface a user's full swap history
/// across cancel/re-create cycles — the on-chain `orders(user)` struct resets
/// `executedSwaps` / `lastExecutedAt` on cancel-and-recreate, but the
/// underlying `DCAExecuted` event log remains. This table is our durable
/// mirror.
model DcaExecution {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress    String
  txHash           String
  /// Block number (uint256 as decimal string).
  blockNumber      String
  /// IDRX minor units (2 decimals) as a decimal string.
  idrxSpentRaw     String
  /// cbBTC minor units (8 decimals) as a decimal string (= sats).
  cbBtcReceivedRaw String
  /// Best-effort on-chain block timestamp.
  executedAt       DateTime?
  createdAt        DateTime @default(now())

  @@unique([walletAddress, txHash])
  @@index([userId])
  @@index([walletAddress, blockNumber])
}

/// Optional local snapshot after mint / for quicker empty states; list view still uses IDRX history API.
model MintRequestSnapshot {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference       String?
  merchantOrderId String?
  toBeMinted      String?
  paymentAmount   String?
  paymentUrl      String?
  networkChainId  String?
  createdAt       DateTime @default(now())
}
